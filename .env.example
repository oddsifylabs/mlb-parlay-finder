ODDS_API_KEY=your_api_key_here
ODDS_API_BASE=https://api.the-odds-api.com/v4
# Optional: cap event scans to manage quota. A normal MLB slate is usually under 30 events.
MAX_MLB_EVENTS=30
# Minimum DK edge vs consensus fair probability. 0.005 = 0.5 percentage points.
MIN_EDGE=0.005

# SQLite history storage. Leave blank to store in ./data/mlb-parlay-finder.sqlite
# SQLITE_DATA_DIR=./data
# SQLITE_DB_PATH=./data/mlb-parlay-finder.sqlite
